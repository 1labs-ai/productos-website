generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Allowed viewers (pre-approved emails)
model AllowedViewer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  company   String?
  addedAt   DateTime @default(now())
  hasViewed Boolean  @default(false)
  viewedAt  DateTime?
  
  // Link to actual viewer data when they view
  viewer    PitchDeckViewer? @relation(fields: [viewerId], references: [id])
  viewerId  String?
  
  @@index([email])
}

// OTP codes for email verification
model OTPCode {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit code
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([email, code])
}

// Pitch Deck Viewers
model PitchDeckViewer {
  id        String   @id @default(cuid())
  
  // Required fields
  name      String
  email     String   @unique
  
  // Optional fields
  phone     String?
  company   String?
  linkedin  String?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  sessions       PitchDeckSession[]
  allowedViewer  AllowedViewer[]
  
  @@index([email])
  @@index([createdAt])
}

// Each viewing session
model PitchDeckSession {
  id        String   @id @default(cuid())
  viewerId  String
  viewer    PitchDeckViewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  
  // Session metadata
  userAgent String?
  ipAddress String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  
  // Relations
  slideViews PitchDeckSlideView[]
  
  @@index([viewerId])
  @@index([startedAt])
}

// Individual slide views within a session
model PitchDeckSlideView {
  id          String   @id @default(cuid())
  sessionId   String
  session     PitchDeckSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  slideIndex  Int      // 0-9 for 10 slides
  slideName   String   // "cover", "problem", etc.
  
  // Time tracking
  viewedAt    DateTime @default(now())
  timeSpentMs Int      @default(0) // milliseconds spent on slide
  
  @@index([sessionId])
  @@index([slideIndex])
}
